# Osiris frontend — environment variables
#
# Copy to .env.local for local development.
# All vars must be prefixed with REACT_APP_ to be exposed to the React build.

# Base URL for the API tier.
REACT_APP_API_BASE_URL=http://localhost:3001

# Per-domain feature flags. Set to "true" to use the API-backed
# repository for that domain; otherwise the mock implementation is used.
#
# Today only vessel search has a working API (the existing vessel-backend).
# Other domains stay mock until their endpoints are built.
REACT_APP_USE_API_VESSEL=false
REACT_APP_USE_API_PORT=false
REACT_APP_USE_API_HISTORICAL=false
REACT_APP_USE_API_AUTH=false
